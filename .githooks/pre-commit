#!/usr/bin/env bash
# Pre-commit hook. Install once after cloning:
#   git config core.hooksPath .githooks
#
# 1. Block any commit that contains unformatted Dart.
# 2. Bump the Flutter app's build number on every commit.
#
# The Flutter app lives in frontend/, so both steps operate there; the repo
# also holds the admin site and the info site, which this hook leaves alone.

set -euo pipefail

# 1. Formatting gate for staged Dart files (paths are repo-relative; dart format
#    finds frontend/pubspec.yaml by walking up from each file).
files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.dart$' || true)
if [ -n "$files" ]; then
  if ! printf '%s\n' "$files" | xargs dart format --output=none --set-exit-if-changed; then
    echo >&2
    echo "✗ Unformatted Dart (above). Fix with:  dart format ." >&2
    exit 1
  fi
fi

# 2. Bump the Flutter app's build number on every commit, then re-stage the
#    bumped pubspec. This is unconditional on purpose: a store upload rejects a
#    reused version code, and CI builds/uploads on a broader set of changes
#    (e.g. frontend/pubspec.lock, dependency bumps) than a narrow app-code path
#    filter would catch. Bumping every time guarantees each commit — and so each
#    build CI might upload — gets a fresh version code. Cheap, and matches the
#    "random patch bumps are fine" convention (same as auslan's hook).
(cd frontend && ./bump_version.sh)
git add frontend/pubspec.yaml
